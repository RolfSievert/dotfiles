[include]
    path = ~/.gituserconfig

[alias]
    st = status
    co = checkout
    cop = "!f() { git checkout \"$1\" && git pull; }; f"
    fco = "!f() { git fetch && git checkout \"$1\"; }; f"
    ci = commit
    ch = cherry-pick
    br = branch
    pullr = pull --recurse-submodules
[init]
	defaultBranch = main
[rebase]
	autostash = true

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    line-numbers = true
    side-by-side = true

[merge]
    conflictStyle = zdiff3
